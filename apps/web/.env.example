# API базовый URL (доступен в браузере)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Серверный секрет для верификации JWT в middleware (Edge runtime).
# ВАЖНО: значение должно ПОЛНОСТЬЮ совпадать с JWT_SECRET в apps/api/.env —
# middleware верифицирует тот же токен, что выдаёт бэкенд.
# Для локальной разработки добавьте это же значение в apps/web/.env.local
JWT_SECRET=your_jwt_secret_here
