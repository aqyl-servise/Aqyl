PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/dbname
JWT_SECRET=generate-with-openssl-rand-hex-64
# Access-token lifetime for B2C / refreshed tokens (default 15m).
JWT_ACCESS_EXPIRES=15m
# Refresh-token lifetime (default 30d).
JWT_REFRESH_EXPIRES=30d
# B2G login keeps a longer access token (no refresh wiring on that flow). Default 1d.
JWT_B2G_ACCESS_EXPIRES=1d
ADMIN_PASSWORD=set-a-strong-admin-password
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
APP_ORIGIN=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Aqyl <noreply@aqyl.kz>
SMS_API_KEY=your_mobizon_api_key_here
NODE_ENV=production
